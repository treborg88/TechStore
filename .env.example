# =============================================================================
# TechStore — Environment Variables
# =============================================================================
# Copy this file to backend/.env (bare-metal) or root .env (Docker Compose).
# Values shown are defaults; uncomment and set only what you need.
# The Setup Wizard can also configure DB credentials at first boot.
# =============================================================================

# ─── Database (PostgreSQL) ───────────────────────────────────────────────────
# DATABASE_URL=postgresql://techstore:techstore@localhost:5432/techstore

# ─── Authentication ─────────────────────────────────────────────────────────
# REQUIRED — server refuses to start without this.
JWT_SECRET=change-me-to-a-random-64-char-string

# ─── Server ─────────────────────────────────────────────────────────────────
# PORT=5001
# NODE_ENV=production

# ─── CORS ───────────────────────────────────────────────────────────────────
# Comma-separated origins. Also configurable from Admin Panel → siteDomain.
# CORS_ORIGIN=https://yourdomain.com

# ─── Email (SMTP) ──────────────────────────────────────────────────────────
# Used for verification codes, password reset, and order invoices.
# Can also be configured from Admin Panel → Email Settings.
# EMAIL_USER=
# EMAIL_PASS=
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587

# ─── Stripe (optional) ─────────────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_test_...

# ─── Docker Compose only ───────────────────────────────────────────────────
# These are used by the "database" service in docker-compose.yml.
# POSTGRES_USER=techstore
# POSTGRES_PASSWORD=techstore
# POSTGRES_DB=techstore
